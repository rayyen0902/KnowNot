{
  "compilerOptions": {
    "target": "es2019",
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@tarojs/taro", "@tarojs/components"]
  },
  "include": ["src/**/*", "config/**/*", "types/**/*", "global.d.ts"],
  "exclude": ["dist", "node_modules", ".temp", ".taro", "coverage"]
}